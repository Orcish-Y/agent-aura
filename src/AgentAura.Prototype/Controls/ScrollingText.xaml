<UserControl x:Class="AgentAura.Prototype.Controls.ScrollingText"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ClipToBounds="True"
             ToolTip="{x:Null}"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded"
             SizeChanged="OnSizeChanged">
  <Grid x:Name="Viewport"
        Background="Transparent"
        ClipToBounds="True"
        MouseEnter="OnMouseEnter"
        MouseLeave="OnMouseLeave">
    <TextBlock x:Name="TruncatedTextContent"
               Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}}"
               HorizontalAlignment="Stretch"
               TextTrimming="CharacterEllipsis"
               TextWrapping="NoWrap" />
    <Canvas x:Name="ScrollingViewport"
            ClipToBounds="True"
            IsHitTestVisible="False"
            Visibility="Collapsed">
      <TextBlock x:Name="ScrollingTextContent"
                 Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 TextTrimming="None"
                 TextWrapping="NoWrap">
        <TextBlock.RenderTransform>
          <TranslateTransform x:Name="TextTransform" />
        </TextBlock.RenderTransform>
      </TextBlock>
    </Canvas>
  </Grid>
</UserControl>
