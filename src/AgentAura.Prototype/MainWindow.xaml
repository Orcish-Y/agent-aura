<Window x:Class="AgentAura.Prototype.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AgentAura.Prototype.Controls"
        xmlns:converters="clr-namespace:AgentAura.Prototype.Converters"
        Title="Agent Aura prototype"
        Width="520"
        Height="320"
        MinWidth="380"
        MinHeight="220"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        MouseEnter="OnWindowMouseEnter"
        MouseLeave="OnWindowMouseLeave"
        StateChanged="OnWindowStateChanged"
        Closing="OnWindowClosing">
  <Window.Resources>
    <converters:StateBrushConverter x:Key="StateBrush" />
    <converters:StateGlyphConverter x:Key="StateGlyph" />
    <Style x:Key="HoverDetailLine" TargetType="FrameworkElement">
      <Setter Property="Visibility" Value="Visible" />
      <Setter Property="Opacity" Value="0" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsHovered}" Value="True">
          <DataTrigger.EnterActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
          <DataTrigger.ExitActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.ExitActions>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="AgentMessageItemContainer" TargetType="Border">
      <Setter Property="Height" Value="42" />
      <Setter Property="ClipToBounds" Value="True" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsHovered}" Value="True">
          <DataTrigger.EnterActions>
            <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Height" To="118" Duration="0:0:0.15" />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
          <DataTrigger.ExitActions>
            <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Height" To="42" Duration="0:0:0.15" />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.ExitActions>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Margin" Value="4,0,0,0" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="Background" Value="#2E3845" />
      <Setter Property="Foreground" Value="#F4F7FA" />
      <Setter Property="BorderBrush" Value="#536273" />
    </Style>
  </Window.Resources>
  <Border Margin="8"
          Background="Transparent">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Border Grid.Row="0"
              Background="#E6141B25"
              Padding="10,10,10,0">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="11,11,0,0" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="IsHitTestVisible" Value="True" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsHeaderVisible}" Value="False">
                <Setter Property="Opacity" Value="0" />
                <Setter Property="IsHitTestVisible" Value="False" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid x:Name="Header"
              Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
            <TextBlock Text="Agent Aura" FontSize="16" FontWeight="SemiBold" Foreground="#F4F7FA" />
            <TextBlock Text="{Binding IntegrationStatus}" FontSize="11" Foreground="#B8C4D2" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Button Content="Pin" Click="OnPinClicked" />
            <Button Content="Minimise" Click="OnMinimiseClicked" />
            <Button Content="Hide" Click="OnHideClicked" />
          </StackPanel>
        </Grid>
      </Border>
      <Border Grid.Row="1"
              Background="#E6141B25"
              Padding="10,0,10,10">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="0,0,11,11" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsHeaderVisible}" Value="False">
                <Setter Property="CornerRadius" Value="11" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <ListBox Grid.Row="0"
               ItemsSource="{Binding Items}"
               Background="Transparent"
               BorderThickness="0"
               Foreground="#F4F7FA"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource AgentMessageItemContainer}"
                    Margin="0,3"
                    Padding="8"
                    CornerRadius="8"
                    Background="#CC202A36"
                    MouseEnter="OnAgentItemMouseEnter"
                    MouseLeave="OnAgentItemMouseLeave">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="22" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="17"
                        Height="17"
                        CornerRadius="9"
                        Background="{Binding State, Converter={StaticResource StateBrush}}"
                        VerticalAlignment="Center">
                  <TextBlock Text="{Binding State, Converter={StaticResource StateGlyph}}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontWeight="Bold"
                             FontSize="11" />
                </Border>
                <controls:ScrollingText Grid.Column="1"
                                        Text="{Binding Title}"
                                        FontWeight="SemiBold" />
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Visibility="{Binding IsHovered, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <Button Content="Edit" Click="OnEditClicked" />
                  <Button Content="Delete" Click="OnDeleteClicked" />
                </StackPanel>
                <controls:ScrollingText Grid.Row="1"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,5,0,0"
                                        Text="{Binding ProjectContext}"
                                        Foreground="#BED0E2"
                                        Style="{StaticResource HoverDetailLine}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Margin="0,5,0,0"
                           Foreground="#BED0E2"
                           Style="{StaticResource HoverDetailLine}">
                  <Run Text="{Binding State, Mode=OneWay}" />
                  <Run Text=" · changed just now · current turn 00:42" />
                </TextBlock>
                <controls:ScrollingText Grid.Row="3"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,5,0,0"
                                        Text="{Binding Detail}"
                                        Foreground="#9DADBD"
                                        Style="{StaticResource HoverDetailLine}" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
          <Button Grid.Row="1"
              Margin="0,8,0,0"
              HorizontalAlignment="Right"
              Content="Flash tray"
              Click="OnFlashTrayClicked" />
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
