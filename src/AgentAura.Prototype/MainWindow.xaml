<Window x:Class="AgentAura.Prototype.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AgentAura.Prototype.Controls"
        xmlns:converters="clr-namespace:AgentAura.Prototype.Converters"
        Title="Agent Aura prototype"
        Width="520"
        Height="320"
        MinWidth="380"
        MinHeight="220"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        MouseEnter="OnWindowMouseEnter"
        MouseLeave="OnWindowMouseLeave"
        StateChanged="OnWindowStateChanged"
        Closing="OnWindowClosing">
  <Window.Resources>
    <converters:StateBrushConverter x:Key="StateBrush" />
    <converters:StateGlyphConverter x:Key="StateGlyph" />
    <Style x:Key="HoverDetailLine" TargetType="FrameworkElement">
      <Setter Property="Visibility" Value="Collapsed" />
      <Setter Property="Opacity" Value="1" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsHovered}" Value="True">
          <Setter Property="Visibility" Value="Visible" />
        </DataTrigger>
        <MultiDataTrigger>
          <MultiDataTrigger.Conditions>
            <Condition Binding="{Binding IsHovered}" Value="True" />
            <Condition Binding="{Binding DataContext.IsMotionEnabled, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
          </MultiDataTrigger.Conditions>
          <Setter Property="Visibility" Value="Visible" />
          <Setter Property="Opacity" Value="0" />
          <MultiDataTrigger.EnterActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
              </Storyboard>
            </BeginStoryboard>
          </MultiDataTrigger.EnterActions>
        </MultiDataTrigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Margin" Value="4,0,0,0" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="Background" Value="#2E3845" />
      <Setter Property="Foreground" Value="#F4F7FA" />
      <Setter Property="BorderBrush" Value="#536273" />
    </Style>
  </Window.Resources>
  <Border Margin="8"
          Padding="10"
          CornerRadius="12"
          Background="#E6141B25"
          BorderBrush="#637286"
          BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid x:Name="Header"
            Visibility="{Binding IsHeaderVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
            Margin="0,0,0,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
          <TextBlock Text="Agent Aura" FontSize="16" FontWeight="SemiBold" Foreground="#F4F7FA" />
          <TextBlock Text="Windows observation-shell prototype" FontSize="11" Foreground="#B8C4D2" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Content="Pin" Click="OnPinClicked" />
          <Button Content="Minimise" Click="OnMinimiseClicked" />
          <Button Content="Hide" Click="OnHideClicked" />
        </StackPanel>
      </Grid>
      <ListBox Grid.Row="1"
               ItemsSource="{Binding Items}"
               Background="Transparent"
               BorderThickness="0"
               Foreground="#F4F7FA"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,3"
                    Padding="8"
                    CornerRadius="8"
                    Background="#CC202A36"
                    MouseEnter="OnAgentItemMouseEnter"
                    MouseLeave="OnAgentItemMouseLeave">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="22" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="17"
                        Height="17"
                        CornerRadius="9"
                        Background="{Binding State, Converter={StaticResource StateBrush}}"
                        VerticalAlignment="Center">
                  <TextBlock Text="{Binding State, Converter={StaticResource StateGlyph}}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontWeight="Bold"
                             FontSize="11" />
                </Border>
                <controls:ScrollingText Grid.Column="1"
                                        Text="{Binding Title}"
                                        IsMotionEnabled="{Binding DataContext.IsMotionEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                        FontWeight="SemiBold" />
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Visibility="{Binding IsHovered, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <Button Content="Edit" Click="OnEditClicked" />
                  <Button Content="Delete" Click="OnDeleteClicked" />
                </StackPanel>
                <controls:ScrollingText Grid.Row="1"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,5,0,0"
                                        Text="{Binding ProjectContext}"
                                        IsMotionEnabled="{Binding DataContext.IsMotionEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Foreground="#BED0E2"
                                        Style="{StaticResource HoverDetailLine}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Margin="0,5,0,0"
                           Foreground="#BED0E2"
                           Style="{StaticResource HoverDetailLine}">
                  <Run Text="{Binding State}" />
                  <Run Text=" · changed just now · current turn 00:42" />
                </TextBlock>
                <controls:ScrollingText Grid.Row="3"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,5,0,0"
                                        Text="{Binding Detail}"
                                        IsMotionEnabled="{Binding DataContext.IsMotionEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Foreground="#9DADBD"
                                        Style="{StaticResource HoverDetailLine}" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <DockPanel Grid.Row="2" Margin="0,8,0,0">
        <CheckBox Content="Reduced motion"
                  IsChecked="{Binding ReducedMotion}"
                  Foreground="#E8EDF4"
                  VerticalAlignment="Center" />
        <Button DockPanel.Dock="Right" Content="Flash tray" Click="OnFlashTrayClicked" />
      </DockPanel>
    </Grid>
  </Border>
</Window>
